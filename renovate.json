{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchPackagePatterns": [
        ".*"
      ],
      "excludePackageNames": [
        "quay.io/victoriametrics/vmstorage"
      ],
      "labels": [
        "functional-test"
      ]
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "postUpdateOptions": [
        "gomodTidy"
      ]
    },
    {
      "matchPackageNames": [
        "go",
        "golang"
      ],
      "groupName": "golang"
    },
    {
      "matchPackageNames": [
        "quay.io/victoriametrics/vmstorage"
      ],
      "groupName": "victoriametrics default versions",
      "labels": [
        "load-test",
        "chaos-test",
        "functional-test",
        "distributed-test"
      ]
    },
    {
      "matchPackageNames": [
        "VictoriaMetrics/operator"
      ],
      "ignoreUnstable": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/",
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "GO_VERSION \\?= (?<currentValue>.*)",
        "ARG GO_VERSION=(?<currentValue>.*)",
        "FROM quay\\.io\\/vrutkovs\\/e2e-runner:golang-(?<currentValue>.*)"
      ],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "golang",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "KIND_VERSION \\?= (?<currentValue>v.*)"
      ],
      "datasourceTemplate": "go",
      "depNameTemplate": "sigs.k8s.io/kind"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "KUBECTL_VERSION \\?= (?<currentValue>v.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes/kubernetes"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "CRUST_GATHER_VERSION \\?= (?<currentValue>v.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "crust-gather/crust-gather"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "VMGATHER_VERSION \\?= (?<currentValue>v.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "VictoriaMetrics/vmgather"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "GINKGO_VERSION \\?= (?<currentValue>v.*)"
      ],
      "datasourceTemplate": "go",
      "depNameTemplate": "github.com/onsi/ginkgo/v2"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "OPERATOR_TAG \\?= (?<currentValue>v.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "VictoriaMetrics/operator"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/",
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "TERRAFORM_VERSION \\?= (?<currentValue>.*)",
        "ARG TERRAFORM_VERSION=(?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "hashicorp/terraform",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "VM_VM(?:SINGLE|CLUSTER)DEFAULT_VERSION \\?= (?<currentValue>v[0-9.]+.*?)(?:-cluster-enterprise|-enterprise-cluster|-cluster|-enterprise)?(?:\\s|$)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "quay.io/victoriametrics/vmstorage",
      "extractVersionTemplate": "^(?<version>v[0-9.]+.*?)(?:-enterprise)?-cluster$"
    }
  ],
  "assignees": [
    "vrutkovs"
  ],
  "reviewers": [
    "vrutkovs"
  ]
}
